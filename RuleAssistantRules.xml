<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE FLExTransRuleGenerator PUBLIC " -//XMLmind//DTD FLExTransRuleGenerator//EN"
"FLExTransRuleGenerator.dtd">
<FLExTransRuleGenerator overwrite_rules="yes">
    <DisjointFeatureSets/>
    <FLExTransRules>
        <FLExTransRule name="Indef N" create_permutations="not_head">
            <Description>The indefinite article should agree in number and gender with the head noun.</Description>
            <Source>
                <Phrase>
                    <Words>
                        <Word category="indf" head="no" id="1">
                            <Features/>
                            <Affixes/>
                        </Word>
                        <Word category="n" head="no" id="2">
                            <Features/>
                            <Affixes/>
                        </Word>
                    </Words>
                </Phrase>
            </Source>
            <Target>
                <Phrase>
                    <Words>
                        <Word category="" head="no" id="1">
                            <Features/>
                            <Affixes>
<Affix type="suffix">
    <Features>
        <Feature label="gender" match="α" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
<Affix type="suffix">
    <Features>
        <Feature label="number" match="β" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
                            </Affixes>
                        </Word>
                        <Word category="" head="yes" id="2">
                            <Features>
<Feature label="gender" match="α" ranking="0" unmarked_default="" value=""/>
                            </Features>
                            <Affixes>
<Affix type="suffix">
    <Features>
        <Feature label="number" match="β" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
                            </Affixes>
                        </Word>
                    </Words>
                </Phrase>
            </Target>
        </FLExTransRule>
        <FLExTransRule name="Indef Adj N" create_permutations="with_head">
            <Description>The indefinite article should agree in number and gender with the head noun. Also the adjective should agree in number and gender with the noun.</Description>
            <Source>
                <Phrase>
                    <Words>
                        <Word category="indf" head="no" id="1">
                            <Features/>
                            <Affixes/>
                        </Word>
                        <Word category="adj" head="no" id="3">
                            <Features/>
                            <Affixes/>
                        </Word>
                        <Word category="n" head="no" id="2">
                            <Features/>
                            <Affixes/>
                        </Word>
                    </Words>
                </Phrase>
            </Source>
            <Target>
                <Phrase>
                    <Words>
                        <Word category="" head="no" id="1">
                            <Features/>
                            <Affixes>
<Affix type="suffix">
    <Features>
        <Feature label="gender" match="α" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
<Affix type="suffix">
    <Features>
        <Feature label="number" match="β" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
                            </Affixes>
                        </Word>
                        <Word category="" head="yes" id="2">
                            <Features>
<Feature label="gender" match="α" ranking="0" unmarked_default="" value=""/>
                            </Features>
                            <Affixes>
<Affix type="suffix">
    <Features>
        <Feature label="number" match="β" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
                            </Affixes>
                        </Word>
                        <Word category="" head="no" id="3">
                            <Features/>
                            <Affixes>
<Affix type="suffix">
    <Features>
        <Feature label="gender" match="α" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
<Affix type="suffix">
    <Features>
        <Feature label="number" match="β" ranking="0" unmarked_default="" value=""/>
    </Features>
</Affix>
                            </Affixes>
                        </Word>
                    </Words>
                </Phrase>
            </Target>
        </FLExTransRule>
    </FLExTransRules>
</FLExTransRuleGenerator>

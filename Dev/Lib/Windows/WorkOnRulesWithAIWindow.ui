            </property>
           </spacer>
          </item>
          <item>
           <widget class="QPushButton" name="createSourceDataButton">
            <property name="toolTip">
             <string>Paste interlinearized source-language example data (tab-separated, e.g. copied from FLEx) to send to the AI with your request. A check mark shows when data has been given.</string>
            </property>
            <property name="text">
             <string>Source Data…</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QPushButton" name="createTargetDataButton">

          <item>
           <widget class="QPushButton" name="createButton">
            <property name="text">
             <string>Create</string>
            </property>
           </widget>
          </item>
          <item>
           <widget class="QCheckBox" name="createMacroCheckbox">
            <property name="toolTip">
             <string>When checked, the AI creates a reusable macro instead of a rule. Macros hold logic that several rules can call.</string>
            </property>
            <property name="text">
             <string>Create a macro instead of a rule</string>
            </property>
           </widget>
          </item>
          <item>
           <spacer name="createActionSpacer">

           <string>Describe the rule you want:</string>
          </property>
         </widget>
        </item>
        <item>
         <widget class="QPlainTextEdit" name="descriptionEdit">
          <property name="placeholderText">
           <string>e.g. In a definite article + noun phrase, remove the article and add the definite singular common gender affix.</string>
          </property>
         </widget>
        </item>
        <item>
